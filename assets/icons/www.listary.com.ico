  <section id="features" class="right-bg flex">
    <div class="container">
      <div class="w-layout-grid features-layout left">
        <div class="align-center-on-mobile-and-below">
          <h2 class="heading-left">Files at your fingertips</h2>
          <p class="text-left center">No more digging through folders to find your file. Listary searches your entire drive instantly, displaying the results in a smart order according to your habits.</p>
        </div><img src="images/Listary-file-search-screenshot.svg" loading="eager" width="680" alt="Dashboard mockup" class="image-4">
      </div>
    </div>
  </section>
  <section class="left-bg height">
    <div class="container">
      <div class="w-layout-grid features-layout right"><img src="images/Listary-launch-apps-screenshot.png" loading="eager" sizes="(max-width: 767px) 100vw, 642px" alt="Dashboard mockup" width="642" srcset="images/Listary-launch-apps-screenshot-p-500.png 500w, images/Listary-launch-apps-screenshot-p-800.png 800w, images/Listary-launch-apps-screenshot-p-1080.png 1080w, images/Listary-launch-apps-screenshot.png 1284w" class="image-4">
        <div class="align-center-on-mobile-and-below">
          <h2 class="heading-left">Launch any app, easier than ever</h2>
          <p class="text-left center">Quickly access your favorite apps with just a few keystrokes. Listary intuitively predicts your desired search result with fuzzy matching and a smart algorithm.</p>
        </div>
      </div>
    </div>
  </section>
  <section class="vertical-section">
    <div class="container vertical">
      <div class="center">
        <h2 class="heading-large">File Search Window <span class="beta">beta</span></h2>
        <p class="text-narrow">Effortlessly glance through sorted results, utilize advanced filters to pinpoint exactly what you&#x27;re looking for, and tailor your search to your workflow for a seamless file management experience.</p>
      </div>
      <div><img src="images/Listary-file-search-window-screenshot.png" loading="eager" width="874.5" sizes="(max-width: 991px) 100vw, 874.5px" alt="Dashboard mockup" srcset="images/Listary-file-search-window-screenshot-p-500.png 500w, images/Listary-file-search-window-screenshot-p-800.png 800w, images/Listary-file-search-window-screenshot-p-1080.png 1080w, images/Listary-file-search-window-screenshot.png 1529w" class="image-large-window boarder-effect"></div>
    </div>
    <div class="container vertical">
      <div class="center">
        <h2 class="heading-large">Quick Switch</h2>
        <div>
          <p class="text-narrow">Tired of digging through multiple folders when Saving/Opening a file? With Quick Switch, just search to instantly jump to the folder you&#x27;re looking for.</p>
          <p class="text-narrow">
            <a href="feature/quick-save-and-open">Learn more →</a>
          </p>
        </div>
      </div>
      <div class="quick-switch-homepage"><img src="images/windows.png" loading="eager" data-w-id="667dd6f3-fe5b-fc11-a05f-16f8106f6caf" sizes="(max-width: 2750px) 100vw, 2750px" alt="Quickly access folders when saving or opening files with Listary. Boost productivity with this must-have tool for every PC. Download free." srcset="images/windows-p-500.png 500w, images/windows-p-800.png 800w, images/windows-p-1080.png 1080w, images/windows-p-1600.png 1600w, images/windows.png 2750w" class="qs-window-first"><img src="images/click.png" loading="eager" data-w-id="667dd6f3-fe5b-fc11-a05f-16f8106f6cb0" sizes="(max-width: 2754px) 100vw, 2754px" alt="Easily locate and save files in organized folders. The interface showcases quick navigation to the &quot;Van Gogh - starry night&quot; folder, containing images like &quot;Starry Night Over the Rhone.jpg&quot; and &quot;The Starry Night.jpg.&quot; Simplify file management with intuitive tools." srcset="images/click-p-500.png 500w, images/click-p-800.png 800w, images/click-p-1080.png 1080w, images/click-p-1600.png 1600w, images/click.png 2754w" class="qs-window-second">
        <div class="qs-toolbar">
          <div class="quick-switch-box"><img src="images/icon_search.svg" loading="lazy" alt="" class="qs-icon logo">
            <div class="quick-switch-wrapper"><img src="images/listary-collection.png" loading="lazy" alt="" class="qs-icon"><img src="images/lisrary-time.png" loading="lazy" alt="" class="qs-icon"><img src="images/listary-setting.png" loading="lazy" alt="" class="qs-icon"></div>
          </div>
          <div data-w-id="667dd6f3-fe5b-fc11-a05f-16f8106f6cb8" class="quick-switch-box recommand">
